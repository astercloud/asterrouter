# Copy this file to .env before starting the bundled Docker deployment.
# Use URL-safe characters in POSTGRES_PASSWORD because it is embedded in the
# PostgreSQL connection URL generated by docker-compose.yml.

POSTGRES_DB=asterrouter
POSTGRES_USER=asterrouter
POSTGRES_PASSWORD=replace-with-a-url-safe-password

# Generate with: openssl rand -hex 32
ASTERROUTER_SECRET_KEY=replace-with-a-stable-random-secret
ASTERROUTER_ADMIN_USERNAME=admin
ASTERROUTER_ADMIN_PASSWORD=replace-with-an-admin-password
# Only used by deploy/docker-compose.standalone.yml:
# ASTERROUTER_DATABASE_URL=postgres://user:password@db.example.com:5432/asterrouter?sslmode=require

# Leave empty to choose the deployment role interactively at /setup.
# Allowed values: personal, relay_operator, enterprise, platform.
ASTERROUTER_DEPLOYMENT_ROLE=
ASTERROUTER_DEMO_MODE=false

# Bind to localhost by default. Set to 0.0.0.0 only behind a trusted proxy/firewall.
ASTERROUTER_BIND_ADDRESS=127.0.0.1
ASTERROUTER_PORT=8080
TZ=UTC
